# Test 3 — Snowflake credentials.
# Copy this file to .env and fill in your values.  The real .env is gitignored
# (see ../.gitignore) and must never be committed.
#
#   cp .env.example .env   &&   edit .env

SNOWFLAKE_ACCOUNT=YOUR_ACCOUNT          # e.g. ORGNAME-ACCOUNTNAME
SNOWFLAKE_USER=YOUR_USER
SNOWFLAKE_PASSWORD=YOUR_PASSWORD
SNOWFLAKE_ROLE=ACCOUNTADMIN

# Created by ingest.py if missing (safe defaults):
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=CRITERION_DB
